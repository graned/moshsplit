# pitboss-api environment configuration
#
# Copy this file to `.env` and fill in your values.
# For production, set these via the container environment.

# PostgreSQL connection string (app schema managed by pitboss-api)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Note: search_path is set programmatically in DbClient::get_conn(), not via URI.
DATABASE_URL=postgres://pitboss:password@localhost:5432/moshsplit

# Server bind configuration
HOST=0.0.0.0
PORT=8080

# Logging verbosity
# Options: error, warn, info, debug, trace
RUST_LOG=info

# CORS allowed origins (comma-separated, no trailing slash)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend base URL for SSO redirect flows
# Development: http://localhost:5173
# Production: https://moshsplit.app
FRONTEND_BASE_URL=http://localhost:5173
