# pitboss-api environment configuration
#
# Copy this file to `.env` and fill in your values.
# For production, set these via the container environment.

# PostgreSQL connection string (app schema managed by pitboss-api)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?search_path=app,public
DATABASE_URL=postgres://pitboss:password@localhost:5432/moshsplit?search_path=app,public

# Server bind configuration
HOST=0.0.0.0
PORT=8080

# Logging verbosity
# Options: error, warn, info, debug, trace
RUST_LOG=info

# CORS allowed origins (comma-separated, no trailing slash)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
