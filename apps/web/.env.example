# API Configuration
# The base URL for the MoshSplit API (Sentinel)
VITE_API_BASE_URL=http://localhost:9000

# Sentinel Auth Service URL (if different from API)
VITE_SENTINEL_URL=http://localhost:9000

# External app integration (for "Go back to <app>" button)
# URL to redirect to when user clicks "Go back"
VITE_EXTERNAL_APP_URL=http://localhost:3000
# Name shown in the button: "Go back to <name>"
VITE_EXTERNAL_APP_NAME=Pitboss