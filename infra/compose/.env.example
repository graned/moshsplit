# MoshSplit Production Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!

# ── Domain / URL ─────────────────────────────────────────────────────────────
# Your production domain (used by Caddy for SSL/TLS)
# Caddy will automatically obtain SSL certificates from Let's Encrypt
MOSHSPLIT_URL=moshsplit.example.com

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
POSTGRES_DB=moshsplit

# Full DATABASE_URL for services that need it
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://postgres:CHANGE_ME_TO_SECURE_PASSWORD@postgres:5432/moshsplit

# ── Sentinel Auth ─────────────────────────────────────────────────────────────
# Generate secure random hex strings for these (64 chars each)
# Use: openssl rand -hex 32
HEX_KEY=CHANGE_ME_TO_64_CHAR_HEX_STRING
CONFIG_ENCRYPTION_KEY=CHANGE_ME_TO_64_CHAR_HEX_STRING

# Sentinel public key for API verification (get from Sentinel after setup)
SENTINEL_PUBLIC_KEY=CHANGE_ME_TO_SENTINEL_PUBLIC_KEY

# Sentinel version for migrations
SENTINEL_VERSION=v1.1.0

# ── OIDC / Auth ───────────────────────────────────────────────────────────────
# OIDC issuer URL (usually your Sentinel URL via Caddy)
OIDC_ISSUER_URL=https://${MOSHSPLIT_URL}/auth

# Frontend URL for CORS and redirects
FRONTEND_URL=https://${MOSHSPLIT_URL}

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://${MOSHSPLIT_URL},http://localhost:5173

# ── Ports ─────────────────────────────────────────────────────────────────────
# Note: In production with Caddy, only ports 80 and 443 are exposed.
# All services are accessed through the reverse proxy.
# These variables are kept for reference and local development.
PITBOSS_API_PORT=8080
SENTINEL_PORT=9000
SENTINEL_UI_PORT=3000
WEB_PORT=80

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── External API Token (for test-external-login) ──────────────────────────────
EXTERNAL_API_TOKEN=sat_e91974dac53da17dd64b0d1bef35049542bd21ffbae0bc68cc7620ce32e5f936

# ── Web App ───────────────────────────────────────────────────────────────────
# API base URL for the frontend (used in production builds)
# For container networking, use the service name
VITE_API_BASE_URL=http://pitboss-api:8080
VITE_SENTINEL_URL=http://sentinel:8000

# ── MoshSplit Version ─────────────────────────────────────────────────────────
# Set to a specific version tag (e.g., v1.2.3) or leave as 'latest'
MOSHSPLIT_VERSION=latest
