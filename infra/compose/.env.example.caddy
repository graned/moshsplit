# MoshSplit Production Environment Variables (Caddy)
# ====================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!

# ── URL Configuration ─────────────────────────────────────────────────────────
# The public-facing domain for your MoshSplit instance
# Caddy will automatically obtain SSL certificates for this domain
MOSHSPLIT_URL=moshsplit.example.com

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
POSTGRES_DB=moshsplit

# Full DATABASE_URL for services that need it
# Format: postgres://user:password@host:port/database
# Note: Host is 'postgres' (service name) for internal networking
DATABASE_URL=postgres://postgres:CHANGE_ME_TO_SECURE_PASSWORD@postgres:5432/moshsplit

# ── Sentinel Auth ─────────────────────────────────────────────────────────────
# Generate secure random hex strings for these (64 chars each)
# Use: openssl rand -hex 32
HEX_KEY=CHANGE_ME_TO_64_CHAR_HEX_STRING
CONFIG_ENCRYPTION_KEY=CHANGE_ME_TO_64_CHAR_HEX_STRING

# Sentinel public key for API verification (get from Sentinel after setup)
SENTINEL_PUBLIC_KEY=CHANGE_ME_TO_SENTINEL_PUBLIC_KEY

# Sentinel version for migrations
SENTINEL_VERSION=v1.1.0

# ── OIDC / Auth ───────────────────────────────────────────────────────────────
# OIDC issuer URL - automatically set to use Caddy URL
# OIDC_ISSUER_URL=https://${MOSHSPLIT_URL}/sentinel

# Frontend URL for CORS and redirects - automatically set
# FRONTEND_URL=https://${MOSHSPLIT_URL}/moshsplit

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# With Caddy, all services use the same origin (no CORS issues in production)
CORS_ALLOWED_ORIGINS=https://${MOSHSPLIT_URL},http://localhost:80,http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── Web App ───────────────────────────────────────────────────────────────────
# API base URL for the frontend
# With Caddy, use relative paths since everything is same-origin
VITE_API_BASE_URL=/pitboss
VITE_SENTINEL_URL=/sentinel

# ── MoshSplit Version ─────────────────────────────────────────────────────────
# Set to a specific version tag (e.g., v1.2.3) or leave as 'latest'
MOSHSPLIT_VERSION=latest

# ── Optional: ACME Configuration ──────────────────────────────────────────────
# For Let's Encrypt staging (testing):
# ACME_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory

# For custom email for certificate notifications:
# ACME_EMAIL=admin@example.com
