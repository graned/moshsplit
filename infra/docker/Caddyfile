# MoshSplit Caddy Reverse Proxy Configuration
# ============================================
# This file configures Caddy as a reverse proxy for all MoshSplit services.
# Caddy automatically handles SSL/TLS certificate provisioning and renewal.
#
# Environment Variables:
#   {$MOSHSPLIT_URL} - Your domain (e.g., moshsplit.example.com)
#
# Routing:
#   sentinel.{$MOSHSPLIT_URL} -> Sentinel UI (management dashboard)
#   /sentinel/*      -> Sentinel API (auth service)
#   /pitboss/*   -> Pitboss API (backend API)
#   /moshsplit/* -> Web frontend (React PWA)
#   /            -> Redirects to /moshsplit/

# ── Sentinel UI (Management Dashboard) ─────────────────────────────────────
# Access at: https://sentinel.viralatas.org/
sentinel.viralatas.org {
    encode gzip zstd

    log {
        output stdout
        format json
    }

    reverse_proxy sentinel-ui:80 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
    }
}

# ── Sentinel Admin (moshsplit.com) ─────────────────────────────────────────
# Access at: https://sentinel.moshsplit.com/
sentinel.moshsplit.com {
    encode gzip zstd

    log {
        output stdout
        format json
    }

    reverse_proxy sentinel-ui:80 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
    }
}

# ── Main Application (viralatas.org) ────────────────────────────────────────
{$MOSHSPLIT_URL} {
    encode gzip zstd

    log {
        output stdout
        format json
    }

    @sentinel {
        path /sentinel/*
    }
    handle @sentinel {
        uri strip_prefix /sentinel
        reverse_proxy sentinel:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    @pitboss {
        path /pitboss/*
    }
    handle @pitboss {
        uri strip_prefix /pitboss
        reverse_proxy pitboss-api:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
            header_up Authorization {header.Authorization}
        }
    }

    @pitbossDirect {
        path /api-docs/*
        path /docs/*
        path /v1/*
    }
    handle @pitbossDirect {
        reverse_proxy pitboss-api:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    @moshsplit {
        path /moshsplit /moshsplit/*
    }
    handle @moshsplit {
        uri strip_prefix /moshsplit
        reverse_proxy web:80 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    @default {
        not path /sentinel/*
        not path /pitboss/*
        not path /moshsplit /moshsplit/*
        not path /api-docs/*
        not path /docs/*
        not path /v1/*
    }
    handle @default {
        reverse_proxy web:80 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    redir / /moshsplit/ 301
}

# ── Main Application (moshsplit.com) ────────────────────────────────────────
# Access at: https://pit.moshsplit.com/
