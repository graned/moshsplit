    redir / /moshsplit/ 301
}

# ── Test External Login (MoshPit) ──────────────────────────────────────────────
# Access at: https://spin.moshsplit.com/
# Only available during integration testing - stop after tests pass
spin.moshsplit.com {
    encode gzip zstd

    log {
        output stdout
        format json
    }

    @sentinel {
        path /sentinel/*
    }
    handle @sentinel {
        uri strip_prefix /sentinel
        reverse_proxy sentinel:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    @pitboss {
        path /pitboss/*
    }
    handle @pitboss {
        uri strip_prefix /pitboss
        reverse_proxy pitboss-api:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
            header_up Authorization {header.Authorization}
        }
    }

    reverse_proxy spin:5174 {
        header_up Host {host}
        header_up X-Real-IP {remote}
    }
}

