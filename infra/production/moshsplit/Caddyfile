# MoshSplit Caddy Reverse Proxy Configuration
# ============================================
# This file configures Caddy as a reverse proxy for all MoshSplit services.
# Caddy automatically handles SSL/TLS certificate provisioning and renewal.
#
# Environment Variables:
#   {$MOSHSPLIT_VIRALATAS_URL} - viralatas.org domain (e.g., split.viralatas.org)
#   {$MOSHSPLIT_URL} - moshsplit.com domain (e.g., pit.moshsplit.com)
#
# Routing (viralatas.org):
#   sentinel.viralatas.org -> Sentinel UI
#   {$MOSHSPLIT_VIRALATAS_URL} -> Main app
#
# Routing (moshsplit.com):
#   sentinel.moshsplit.com -> Sentinel UI
#   pit.moshsplit.com -> Main app
#   spin.moshsplit.com -> Test app (spin)

# ── Sentinel UI (Management Dashboard) ─────────────────────────────────────
# Access at: https://sentinel.viralatas.org/
sentinel.viralatas.org {
    encode gzip zstd

    log {
        output stdout
        format json
    }

    reverse_proxy sentinel-ui:80 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
    }
}

# ── Sentinel Admin (moshsplit.com) ─────────────────────────────────────────
# Access at: https://sentinel.moshsplit.com/
sentinel.moshsplit.com {
    encode gzip zstd

    log {
        output stdout
        format json
    }

    reverse_proxy sentinel-ui:80 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
    }
}

# ── Main Application (viralatas.org) ────────────────────────────────────────
# Access at: https://split.viralatas.org/
{$MOSHSPLIT_VIRALATAS_URL} {
    encode gzip zstd

    log {
        output stdout
        format json
    }

    @sentinel {
        path /sentinel/*
    }
    handle @sentinel {
        uri strip_prefix /sentinel
        reverse_proxy sentinel:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    @pitboss {
        path /pitboss/*
    }
    handle @pitboss {
        uri strip_prefix /pitboss
        reverse_proxy pitboss-api:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
            header_up Authorization {header.Authorization}
        }
    }

    @pitbossDirect {
        path /api-docs/*
        path /docs/*
        path /v1/*
    }
    handle @pitbossDirect {
        reverse_proxy pitboss-api:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    @moshsplit {
        path /moshsplit /moshsplit/*
    }
    handle @moshsplit {
        uri strip_prefix /moshsplit
        reverse_proxy web:80 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    @default {
        not path /sentinel/*
        not path /pitboss/*
        not path /moshsplit /moshsplit/*
        not path /api-docs/*
        not path /docs/*
        not path /v1/*
    }
    handle @default {
        reverse_proxy web:80 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    redir / /moshsplit/ 301
}

# ── Main Application (moshsplit.com) ────────────────────────────────────────
# Access at: https://pit.moshsplit.com/
